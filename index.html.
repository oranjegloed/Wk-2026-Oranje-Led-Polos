<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Hersteld | Directie Bouw & Innovatie</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { background-color: #000; color: #fff; font-family: ui-sans-serif, system-ui, sans-serif; }
        .accent { color: #ff5e00; }
        .bg-accent { background-color: #ff5e00; }
    </style>
</head>
<body>

    <!-- Navigatie -->
    <nav class="p-5 border-b border-gray-800 bg-black flex justify-between items-center sticky top-0 z-50">
        <div class="font-black uppercase tracking-tighter text-xl">Aannemer <span class="accent">RDAM</span></div>
        <a href="https://www.paypal.com/ncp/payment/YD8CBSVSF3DPY class="bg-accent text-black px-4 py-2 font-bold text-xs uppercase">BESTEL NU</a>
    </nav>

    <!-- Hoofdinhoud -->
    <header class="py-20 px-6 max-w-4xl mx-auto text-center md:text-left">
        <h1 class="text-5xl md:text-7xl font-extrabold uppercase mb-6 leading-none">
            Structuur <br><span class="accent">Hersteld.</span>
        </h1>
        <p class="text-gray-400 text-lg mb-10 border-l-4 border-orange-600 pl-6">
            Eigenaar-directeur. Focus op bouwprojecten en gecertificeerd modelontwerp (BOIP). 18 uur per dag inzet voor resultaat.
        </p>
    </header>

    <!-- Sectie: Diensten -->
    <section class="bg-white text-black py-16 px-6">
        <div class="max-w-4xl mx-auto grid md:grid-cols-2 gap-10">
            <div class="border-b-4 border-orange-600 pb-6">
                <h2 class="text-2xl font-black uppercase mb-3">Bouw</h2>
                <p>Nieuwe projecten in Rotterdam. Directe aansturing van eigen personeel.</p>
            </div>
            <div class="border-b-4 border-orange-600 pb-6">
                <h2 class="text-2xl font-black uppercase mb-3">Innovatie</h2>
                <p>BOIP-gecertificeerd model patent voor materiaal en kleding.</p>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="py-20 px-6 bg-gray-900">
        <div class="max-w-xl mx-auto">
            <h2 class="text-3xl font-black uppercase mb-8 text-center accent">Direct Schakelen</h2>
            <form class="space-y-4">
                <input type="text" placeholder="NAAM" class="w-full bg-black border border-gray-700 p-4 outline-none focus:border-orange-600">
                <textarea placeholder="PROJECTDETAILS" class="w-full bg-black border border-gray-700 p-4 h-32 outline-none focus:border-orange-600"></textarea>
                <button class="w-full bg-accent text-black font-black py-4 uppercase tracking-widest">Verstuur</button>
            </form>
        </div>
    </section>

    <!-- DEZE TAGS WAREN WEG - HIERONDER WORDT ALLES GESLOTEN -->
    <footer class="p-10 text-center text-gray-700 text-xs font-bold uppercase border-t border-gray-800">
        &copy; 2026 Rotterdam Bouw & Innovatie
    </footer>

</body>
</html>
