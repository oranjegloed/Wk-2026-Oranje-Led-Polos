<!DOCTYPE html>
<html lang="nl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Uw Bedrijfsnaam | Bouw & Realisatie</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body { font-family: 'Helvetica Neue', sans-serif; }
        .hero-gradient { background: linear-gradient(rgba(0,0,0,0.6), rgba(0,0,0,0.6)), url('https://images.unsplash.com/photo-1541888946425-d81bb19480c5?q=80&w=2070&auto=format&fit=crop'); background-size: cover; background-position: center; }
    </style>
</head>
<body class="bg-gray-50 text-gray-900">

    <!-- Navigatie -->
    <nav class="bg-white shadow-md p-4 sticky top-0 z-50">
        <div class="container mx-auto flex justify-between items-center">
            <h1 class="text-2xl font-bold text-orange-600">BOUW<span class="text-gray-800">MEESTER</span></h1>
            <div class="hidden md:flex space-x-6 font-semibold text-sm uppercase">
                <a href="#projecten" class="hover:text-orange-600 transition">Projecten</a>
                <a href="#over" class="hover:text-orange-600 transition">Over ons</a>
                <a href="#contact" class="bg-orange-600 text-white px-4 py-2 rounded hover:bg-orange-700 transition">Contact</a>
            </div>
        </div>
    </nav>

    <!-- Hero Sectie -->
    <header class="hero-gradient h-[70vh] flex items-center justify-center text-center text-white px-4">
        <div>
            <h2 class="text-4xl md:text-6xl font-extrabold mb-4 uppercase tracking-tight">Kwaliteit in elke constructie</h2>
            <p class="text-lg md:text-xl mb-8 max-w-2xl mx-auto text-gray-200">Uw partner in Rotterdam voor innovatieve bouwprojecten en gecertificeerd modelontwerp.</p>
            <a href="#contact" class="bg-orange-600 hover:bg-orange-700 text-white font-bold py-3 px-8 rounded-full text-lg transition shadow-lg">Start een project</a>
        </div>
    </header>

    <!-- Info Sectie -->
    <section id="projecten" class="py-20 container mx-auto px-4">
        <div class="grid md:grid-cols-3 gap-8">
            <div class="bg-white p-8 border-t-4 border-orange-600 shadow-sm">
                <h3 class="text-xl font-bold mb-3">Bouw & Advies</h3>
                <p class="text-gray-600">Gespecialiseerd in complexe bouwprojecten waarbij snelheid en precisie essentieel zijn.</p>
            </div>
            <div class="bg-white p-8 border-t-4 border-orange-600 shadow-sm">
                <h3 class="text-xl font-bold mb-3">Gecertificeerd Ontwerp</h3>
                <p class="text-gray-600">Officieel BOIP-gecertificeerde modellen voor unieke kleding- en materiaalcombinaties.</p>
            </div>
            <div class="bg-white p-8 border-t-4 border-orange-600 shadow-sm">
                <h3 class="text-xl font-bold mb-3">Ondernemerschap</h3>
                <p class="text-gray-600">Van visie naar realisatie: wij denken mee met de zakelijke kant van elk project.</p>
            </div>
        </div>
    </section>

    <!-- Contact -->
    <section id="contact" class="bg-gray-900 text-white py-20">
        <div class="container mx-auto px-4 text-center">
            <h2 class="text-3xl font-bold mb-8">Nieuw project in Rotterdam?</h2>
            <p class="mb-8 text-gray-400 text-lg">Wij werken 18 uur per dag wanneer nodig om uw doelen te bereiken.</p>
            <div class="max-w-md mx-auto bg-white p-6 rounded-lg text-gray-900">
                <form>
                    <input type="text" placeholder="Uw naam" class="w-full border p-3 mb-4 rounded focus:outline-orange-600">
                    <input type="email" placeholder="E-mailadres" class="w-full border p-3 mb-4 rounded focus:outline-orange-600">
                    <textarea placeholder="Vertel over uw project" class="w-full border p-3 mb-4 rounded h-32 focus:outline-orange-600"></textarea>
                    <button class="w-full bg-orange-600 text-white font-bold py-3 rounded hover:bg-orange-700 transition">Verstuur Aanvraag</button>
                </form>
            </div>
        </div>
    </section>

    <footer class="bg-gray-950 text-gray-500 py-6 text-center text-sm">
        &copy; 2026 Uw Bedrijf - Rotterdam. Alle rechten voorbehouden.
    </footer>

</body>
</html>
